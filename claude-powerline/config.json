{
  "display": {
    "padding": 1,
    "style": "capsule",
    "charset": "unicode",
    "colorCompatibility": "auto",
    "autoWrap": true,
    "lines": [
      {
        "segments": {
          "model": {
            "enabled": true
          },
          "context": {
            "enabled": true,
            "showPercentageOnly": false,
            "displayStyle": "blocks"
          },
          "block": {
            "enabled": true,
            "type": "weighted",
            "burnType": "tokens"
          }
        }
      },
      {
        "segments": {
          "git": {
            "enabled": true,
            "showSha": true,
            "showWorkingTree": true,
            "showOperation": true,
            "showTag": true,
            "showTimeSinceCommit": true,
            "showStashCount": true,
            "showUpstream": true,
            "showRepoName": true
          }
        }
      }
    ]
  },
  "budget": {
    "session": {
      "warningThreshold": 80
    },
    "today": {
      "amount": 5.0,
      "warningThreshold": 80
    },
    "block": {
      "amount": 20000000,
      "type": "tokens",
      "warningThreshold": 80
    }
  },
  "modelContextLimits": {
    "sonnet": 200000
  }
}
